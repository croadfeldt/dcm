    "dcm_event": {
      "type": "object",
      "description": "A DCM event. The base envelope is always present. The payload object schema is determined by event_type.",
      "allOf": [
        { "$ref": "#/$defs/base_event_envelope" }
      ],
      "unevaluatedProperties": false
    }

  },

  "$ref": "#/$defs/dcm_event"
}
