{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dcm-project.io/schemas/providers/v1",
  "title": "DCM Provider Schemas",
  "description": "JSON Schema for the unified provider base contract and all 11 provider capability extensions. See data-model/A-provider-contract.md and specifications/dcm-registration-spec.md.",

  "$defs": {

    "provider_type": {
      "type": "string",
      "enum": [
        "service",
        "information",
        "storage",
        "meta",
        "policy",
        "credential",
        "auth",
        "notification",
        "message_bus",
        "registry",
        "peer_dcm",
        "itsm"
      ],
      "description": "The 12 DCM provider types. Each maps to a distinct capability extension schema. ITSM Provider (doc 42) is the 12th type — bidirectional ITSM integration."
    },

    "provider_status": {
      "type": "string",
      "enum": [
        "SUBMITTED",
        "VALIDATING",
        "PENDING_APPROVAL",
        "ACTIVE",
        "SUSPENDED",
        "DEREGISTERING",
        "DEREGISTERED",
        "FORCED_DEREGISTERED"
      ]
    },

    "trust_posture": {
      "type": "string",
      "enum": ["verified", "vouched", "provisional"]
    },

    "provider_health_response": {
      "type": "object",
      "required": ["status", "version"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["healthy", "degraded", "unhealthy"]
        },
        "version": { "type": "string" },
        "capabilities_available": {
          "type": "array",
          "items": { "type": "string" }
        },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "description": "Provider-specific detail. DCM treats as opaque."
        }
      }
    },

    "certificate_declaration": {
      "type": "object",
      "required": ["pem", "ca_chain", "rotation_interval"],
      "additionalProperties": false,
      "properties": {
        "pem":              { "type": "string", "description": "PEM-encoded provider certificate" },
        "ca_chain":         { "type": "string", "description": "PEM-encoded CA chain" },
        "rotation_interval": { "$ref": "dcm-common.json#/$defs/iso8601_duration", "description": "How frequently the provider rotates this certificate" },
        "expires_at":        { "$ref": "dcm-common.json#/$defs/iso8601_datetime" }
      }
    },

    "base_provider_registration": {
      "type": "object",
      "title": "Base Provider Registration",
      "description": "Fields required in every provider registration regardless of type.",
      "required": [
        "artifact_metadata",
        "provider_type_id",
        "display_name",
        "sovereignty_declaration",
        "health_endpoint",
        "certificate",
        "capability_extension"
      ],
      "properties": {
        "artifact_metadata":       { "$ref": "dcm-common.json#/$defs/artifact_metadata" },
        "provider_type_id":        { "$ref": "#/$defs/provider_type" },
        "display_name":            { "type": "string", "maxLength": 256 },
        "description":             { "type": "string" },
        "status":                  { "$ref": "#/$defs/provider_status" },

        "sovereignty_declaration": { "$ref": "dcm-common.json#/$defs/sovereignty_declaration" },

        "accreditations": {
          "type": "array",
          "items": { "$ref": "dcm-common.json#/$defs/accreditation_ref" }
        },

        "health_endpoint": {
          "type": "string",
          "format": "uri"
        },
        "health_poll_interval": {
          "$ref": "dcm-common.json#/$defs/iso8601_duration",
          "default": "PT5M"
        },
        "failure_threshold": {
          "type": "integer",
          "minimum": 1,
          "default": 3,
          "description": "Consecutive failed health checks before status transitions to DEGRADED"
        },

        "certificate": { "$ref": "#/$defs/certificate_declaration" },

        "trust_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "DCM-computed trust score (0.0–1.0). Not set by provider; updated by DCM based on health, accreditation, and governance matrix checks."
        },

        "capability_extension": {
          "type": "object",
          "description": "Provider-type-specific capability declaration. Schema determined by provider_type_id."
        }
      }
    },

    "service_provider_capabilities": {
      "type": "object",
      "title": "Service Provider Capability Extension",
      "description": "Capabilities for a Service Provider — realizes physical or virtual infrastructure resources.",
      "required": ["offered_resource_types", "services_endpoint"],
      "additionalProperties": false,
      "properties": {
        "offered_resource_types": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "dcm-common.json#/$defs/resource_type_fqn" },
          "description": "Resource types this provider can realize (e.g., Compute.VirtualMachine)"
        },
        "services_endpoint": { "type": "string", "format": "uri" },
        "discovery_endpoint": { "type": "string", "format": "uri" },
        "reserve_query_endpoint": { "type": "string", "format": "uri" },
        "max_concurrent_realizations": { "type": "integer", "minimum": 1 },
        "realization_timeout_default": { "$ref": "dcm-common.json#/$defs/iso8601_duration" },
        "supports_suspension": { "type": "boolean", "default": false },
        "supports_rehydration": { "type": "boolean", "default": false },
        "cost_metadata": {
          "type": "object",
          "additionalProperties": true,
          "description": "Provider-declared cost data consumed by the Cost Analysis component"
        }
      }
    },

    "information_provider_capabilities": {
      "type": "object",
      "title": "Information Provider Capability Extension",
      "required": ["authority_scope", "interaction_model"],
      "additionalProperties": false,
      "properties": {
        "authority_scope": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Field paths or resource type domains this provider has authority over (e.g., Network.VLAN.vlan_id)"
        },
        "interaction_model": {
          "type": "string",
          "enum": ["push", "pull", "both"],
          "description": "push: provider pushes updates to DCM. pull: DCM queries provider. both: supports either."
        },
        "push_endpoint": { "type": "string", "format": "uri", "description": "DCM endpoint where provider pushes updates (if interaction_model is push or both)" },
        "pull_endpoint":  { "type": "string", "format": "uri", "description": "Provider endpoint DCM queries (if interaction_model is pull or both)" },
        "write_back_endpoint": { "type": "string", "format": "uri", "description": "Provider endpoint for DCM-initiated write-back operations" },
        "schema_endpoint": { "type": "string", "format": "uri", "description": "Where DCM retrieves the provider's extended field schema" },
        "confidence_model": { "type": "string", "enum": ["declared", "computed"], "default": "declared" },
        "max_staleness": { "$ref": "dcm-common.json#/$defs/iso8601_duration" }
      }
    },

    "storage_provider_capabilities": {
      "type": "object",
      "title": "Storage Provider Capability Extension",
      "required": ["storage_sub_type", "read_endpoint", "write_endpoint"],
      "additionalProperties": false,
      "properties": {
        "storage_sub_type": {
          "type": "string",
          "enum": ["gitops_store", "event_stream", "snapshot_store", "audit_store", "search_index", "log_store"],
          "description": "Sub-type within Storage Provider. Each has specific guarantees (write-once, append-only, etc.)"
        },
        "read_endpoint":  { "type": "string", "format": "uri" },
        "write_endpoint": { "type": "string", "format": "uri" },
        "durability_guarantee": {
          "type": "string",
          "enum": ["best_effort", "durable", "immutable", "write_once"],
          "description": "immutable and write_once prevent deletion; append-only stores must use these."
        },
        "replication_factor": { "type": "integer", "minimum": 1 },
        "encryption_at_rest": { "type": "boolean" },
        "retention_policy": {
          "type": "object",
          "properties": {
            "default_retention": { "$ref": "dcm-common.json#/$defs/iso8601_duration" },
            "minimum_retention": { "$ref": "dcm-common.json#/$defs/iso8601_duration" }
          }
        }
      }
    },

    "meta_provider_capabilities": {
      "type": "object",
      "title": "Meta Provider Capability Extension",
      "description": "Composes multiple sub-providers to deliver a higher-order composite service.",
      "required": ["offered_composite_types", "constituent_providers"],
      "additionalProperties": false,
      "properties": {
        "offered_composite_types": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "dcm-common.json#/$defs/resource_type_fqn" }
        },
        "constituent_providers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["provider_uuid", "role"],
            "properties": {
              "provider_uuid": { "$ref": "dcm-common.json#/$defs/uuid" },
              "role": { "type": "string" },
              "required": { "type": "boolean", "default": true }
            }
          }
        },
        "composition_endpoint": { "type": "string", "format": "uri" },
        "compensation_strategy": {
          "type": "string",
          "enum": ["rollback_all", "rollback_failed", "notify_and_wait", "best_effort"],
          "description": "What to do if a constituent fails mid-composition"
        },
        "composition_visibility": {
          "type": "string",
          "enum": ["opaque", "transparent", "selective"]
        }
      }
    },

    "policy_provider_capabilities": {
      "type": "object",
      "title": "Policy Provider Capability Extension",
      "description": "An external policy engine that evaluates DCM policies (e.g., OPA, Sentinel).",
      "required": ["evaluation_endpoint", "supported_policy_types"],
      "additionalProperties": false,
      "properties": {
        "evaluation_endpoint": { "type": "string", "format": "uri" },
        "supported_policy_types": {
          "type": "array",
          "items": { "$ref": "schemas/policies/dcm-policies.json#/$defs/policy_type" }
        },
        "evaluation_mode": { "type": "string", "enum": ["sync", "async"], "default": "sync" },
        "bundle_endpoint": { "type": "string", "format": "uri", "description": "Where DCM retrieves policy bundles for local caching" },
        "rego_compatible": { "type": "boolean", "description": "Provider is OPA/Rego compatible" }
      }
    },

    "credential_provider_capabilities": {
      "type": "object",
      "title": "Credential Provider Capability Extension",
      "description": "Issues, stores, rotates, and revokes credentials and secrets.",
      "required": ["issue_endpoint", "credential_types"],
      "additionalProperties": false,
      "properties": {
        "issue_endpoint":  { "type": "string", "format": "uri" },
        "rotate_endpoint": { "type": "string", "format": "uri" },
        "revoke_endpoint": { "type": "string", "format": "uri" },
        "credential_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["api_key", "x509_certificate", "service_account_token", "kubeconfig", "ssh_key", "tls_certificate", "dynamic_secret"]
          }
        },
        "dynamic_secrets":   { "type": "boolean", "default": false, "description": "Generates credentials on demand; expires after single use or short TTL" },
        "hsm_backed":        { "type": "boolean", "default": false },
        "fips_140_level":    { "type": "integer", "enum": [1, 2, 3] },
        "max_credential_ttl": { "$ref": "dcm-common.json#/$defs/iso8601_duration" }
      }
    },

    "auth_provider_capabilities": {
      "type": "object",
      "title": "Auth Provider Capability Extension",
      "description": "Authenticates actors and resolves group/role membership for RBAC.",
      "required": ["auth_endpoint", "supported_auth_modes"],
      "additionalProperties": false,
      "properties": {
        "auth_endpoint":   { "type": "string", "format": "uri" },
        "token_endpoint":  { "type": "string", "format": "uri" },
        "introspect_endpoint": { "type": "string", "format": "uri" },
        "group_endpoint":  { "type": "string", "format": "uri" },
        "scim_endpoint":   { "type": "string", "format": "uri" },
        "supported_auth_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["static_api_key", "local_users", "github_oauth", "ldap", "freeipa", "active_directory", "oidc", "saml", "mtls"]
          }
        },
        "mfa_supported":    { "type": "boolean" },
        "scim_supported":   { "type": "boolean" },
        "token_ttl_default": { "$ref": "dcm-common.json#/$defs/iso8601_duration" }
      }
    },

    "notification_provider_capabilities": {
      "type": "object",
      "title": "Notification Provider Capability Extension",
      "description": "Delivers notifications to actors via declared channels.",
      "required": ["delivery_endpoint", "supported_channels"],
      "additionalProperties": false,
      "properties": {
        "delivery_endpoint":  { "type": "string", "format": "uri" },
        "supported_channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["email", "slack", "teams", "pagerduty", "webhook", "sms", "in_app"]
          }
        },
        "delivery_guarantee": {
          "type": "string",
          "enum": ["best_effort", "at_least_once"],
          "default": "at_least_once"
        },
        "max_retry_attempts": { "type": "integer", "minimum": 0, "default": 3 },
        "retry_interval":     { "$ref": "dcm-common.json#/$defs/iso8601_duration" }
      }
    },

    "message_bus_capabilities": {
      "type": "object",
      "title": "Message Bus Capability Extension",
      "description": "Provides publish/subscribe messaging for DCM internal and external event routing.",
      "required": ["publish_endpoint", "subscribe_endpoint"],
      "additionalProperties": false,
      "properties": {
        "publish_endpoint":   { "type": "string", "format": "uri" },
        "subscribe_endpoint": { "type": "string", "format": "uri" },
        "supported_protocols": {
          "type": "array",
          "items": { "type": "string", "enum": ["amqp", "kafka", "nats", "mqtt", "webhook"] }
        },
        "persistence":    { "type": "boolean", "default": true },
        "max_message_size_bytes": { "type": "integer" },
        "delivery_guarantee": {
          "type": "string",
          "enum": ["at_most_once", "at_least_once", "exactly_once"],
          "default": "at_least_once"
        }
      }
    },

    "registry_provider_capabilities": {
      "type": "object",
      "title": "Registry Capability Extension",
      "description": "Hosts and serves the Resource Type Registry — the catalog of all declared resource types.",
      "required": ["registry_endpoint", "supported_tiers"],
      "additionalProperties": false,
      "properties": {
        "registry_endpoint": { "type": "string", "format": "uri" },
        "search_endpoint":   { "type": "string", "format": "uri" },
        "sync_endpoint":     { "type": "string", "format": "uri" },
        "supported_tiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["dcm_system", "verified_community", "organization"]
          }
        },
        "offline_bundle_endpoint": { "type": "string", "format": "uri", "description": "For air-gapped deployments" },
        "gpg_signing_key_endpoint": { "type": "string", "format": "uri" }
      }
    },

    "peer_dcm_capabilities": {
      "type": "object",
      "title": "Peer DCM Capability Extension",
      "description": "Another DCM instance participating in a federation. Enables cross-instance request routing, audit correlation, and drift detection.",
      "required": ["dcm_api_endpoint", "trust_posture"],
      "additionalProperties": false,
      "properties": {
        "dcm_api_endpoint":    { "type": "string", "format": "uri" },
        "federation_endpoint": { "type": "string", "format": "uri" },
        "audit_endpoint":      { "type": "string", "format": "uri" },
        "trust_posture":       { "$ref": "#/$defs/trust_posture" },
        "dcm_version":         { "$ref": "dcm-common.json#/$defs/semver" },
        "federation_scope": {
          "type": "string",
          "enum": ["full", "read_only", "audit_only", "resource_routing_only"],
          "description": "What this peer DCM is authorized to do in the federation"
        },
        "sovereignty_declaration": { "$ref": "dcm-common.json#/$defs/sovereignty_declaration" }
      }
    },

    "capability_extension": {
      "oneOf": [
        { "$ref": "#/$defs/service_provider_capabilities" },
        { "$ref": "#/$defs/information_provider_capabilities" },
        { "$ref": "#/$defs/storage_provider_capabilities" },
        { "$ref": "#/$defs/meta_provider_capabilities" },
        { "$ref": "#/$defs/policy_provider_capabilities" },
        { "$ref": "#/$defs/credential_provider_capabilities" },
        { "$ref": "#/$defs/auth_provider_capabilities" },
        { "$ref": "#/$defs/notification_provider_capabilities" },
        { "$ref": "#/$defs/message_bus_capabilities" },
        { "$ref": "#/$defs/registry_provider_capabilities" },
        { "$ref": "#/$defs/peer_dcm_capabilities" }
      ]
    },

    "provider_registration": {
      "allOf": [
        { "$ref": "#/$defs/base_provider_registration" }
      ],
      "unevaluatedProperties": false
    }

  },

  "$ref": "#/$defs/base_provider_registration"
}
